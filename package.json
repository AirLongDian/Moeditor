{
  "name": "moeditor",
  "version": "2.0.0",
  "description": "Your all-purpose markdown editor",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k -n vite,tsc,electron \"vite\" \"tsc -p tsconfig.main.json\" \"wait-on http://localhost:5173 && electron .\"",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:renderer && npm run build:main",
    "start": "electron .",
    "dist": "npm run build && electron-builder",
    "dist:snap": "npm run build && electron-builder --linux snap"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Menci/Moeditor.git"
  },
  "keywords": [
    "markdown",
    "editor",
    "electron"
  ],
  "author": "Menci",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/Menci/Moeditor/issues"
  },
  "homepage": "https://github.com/Menci/Moeditor#readme",
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/commands": "^6.8.0",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/language": "^6.11.0",
    "@codemirror/search": "^6.5.0",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.36.0",
    "@codemirror/theme-one-dark": "^6.1.0",
    "electron-store": "^10.0.0",
    "highlight.js": "^11.11.0",
    "katex": "^0.16.0",
    "markdown-it": "^14.1.0",
    "markdown-it-texmath": "^1.0.0",
    "mermaid": "^11.4.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/katex": "^0.16.0",
    "@types/markdown-it": "^14.1.0",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.1.0",
    "electron": "^39.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "org.moeditor.app",
    "productName": "Moeditor",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "static/**/*",
      "themes/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "snap"
      ],
      "icon": "static/icons/Moeditor.png",
      "category": "Office"
    },
    "mac": {
      "icon": "static/icons/Moeditor.icns",
      "category": "public.app-category.productivity"
    },
    "win": {
      "icon": "static/icons/Moeditor.ico"
    }
  }
}
